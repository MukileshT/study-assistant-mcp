# ===================================
# Study Assistant MCP - Environment Variables
# ===================================

# API Keys
# ---------
# Get your Gemini API key from: https://ai.google.dev
GOOGLE_API_KEY=your_gemini_api_key_here

# Get your Groq API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Notion Integration
# ------------------
# Create integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_integration_token_here

# Your Notion database ID (create a database for notes first)
NOTION_DATABASE_ID=your_database_id_here

# Optional: Separate database for daily plans
NOTION_PLANS_DATABASE_ID=your_plans_database_id_here

# Application Settings
# --------------------
# Application environment (development, production)
APP_ENV=development

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Local storage path for cache and uploads
DATA_DIR=./data

# Maximum image file size in MB
MAX_IMAGE_SIZE_MB=10

# Model Configuration
# -------------------
# Primary vision model (gemini-1.5-flash, gemini-1.5-pro)
VISION_MODEL=gemini-1.5-flash

# Primary text model (llama-3.1-70b-versatile, mixtral-8x7b-32768)
TEXT_MODEL=llama-3.1-70b-versatile

# Planning model (gemini-1.5-pro, gemini-1.5-flash)
PLANNING_MODEL=gemini-1.5-pro

# API rate limiting (requests per minute)
GEMINI_RPM_LIMIT=15
GROQ_RPM_LIMIT=30

# Feature Flags
# -------------
# Enable local model fallback (requires Ollama)
ENABLE_LOCAL_MODELS=false

# Enable caching for processed notes
ENABLE_CACHING=true

# Auto-generate daily plans
AUTO_GENERATE_PLANS=true

# Plan generation time (24-hour format, e.g., 20:00 for 8 PM)
PLAN_GENERATION_TIME=20:00

# User Preferences (can be overridden in config)
# -----------------------------------------------
# Learning style (visual, auditory, kinesthetic, reading_writing)
LEARNING_STYLE=visual

# Note detail level (minimal, standard, detailed)
NOTE_DETAIL_LEVEL=standard

# Timezone (for scheduling)
TIMEZONE=America/New_York